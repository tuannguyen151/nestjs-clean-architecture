{
  "servers": {
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}"
      ],
      "env": {
        "PATH": "${input:PATH}"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
      }
    }
  },
  "inputs": [
    {
      "type": "promptString",
      "id": "CONTEXT7_API_KEY",
      "description": "Enter your Context7 API key (e.g., ctx7sk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)",
      "password": true
    },
    {
      "type": "promptString",
      "id": "PATH",
      "description": "Enter your PATH environment variable (e.g., /usr/local/bin:/usr/bin:/bin)",
      "password": true
    }
  ]
}
