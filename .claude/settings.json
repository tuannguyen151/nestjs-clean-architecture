{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-changed-files.sh",
            "timeout": 30,
            "statusMessage": "[Hook] Formatting..."
          }
        ]
      }
    ]
  }
}
