## Infrastructure Common Security (src/infrastructure/common)

### Guards Security (src/infrastructure/common/guards)
- Implement JWT authentication guards
- Create role-based authorization guards
- Implement resource-based authorization guards
- Use dependency injection for guard dependencies
- Handle guard failures gracefully

```typescript
// Good: Secure guard (src/infrastructure/common/guards)
@Injectable()
export class ResourceOwnerGuard implements CanActivate {
  constructor(private readonly userService: UserService) {}

  async canActivate(context: ExecutionContext): Promise<boolean> {
    const request = context.switchToHttp().getRequest();
    const user = request.user;
    const resourceId = request.params.id;

    if (!user || !resourceId) {
      return false;
    }

    return await this.userService.isResourceOwner(user.id, resourceId);
  }
}
```

