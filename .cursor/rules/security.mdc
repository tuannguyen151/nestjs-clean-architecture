@UseGuards(JwtAuthGuard, RolesGuard)
export class UserController {
  @Post()
  @UsePipes(new ValidationPipe({ transform: true, whitelist: true }))
  @UseInterceptors(LoggingInterceptor)
  async createUser(@Body() dto: CreateUserDto): Promise<UserPresenter> {
    // Secure implementation
  }
}
```

### DTOs Validation (src/adapters/controllers/[feature]/dto)
- Use class-validator for all input validation
- Implement sanitization decorators
- Use whitelist: true to strip unknown properties
- Validate nested objects properly
- Implement custom validators for business rules

```typescript
// Good: Secure DTO (src/adapters/controllers/[feature]/dto)
export class CreateUserDto {
  @IsEmail()
  @IsNotEmpty()
  @Sanitize()
  email: string;

  @IsString()
  @MinLength(8)
  @Matches(/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]/)
  password: string;

  @IsOptional()
  @IsString()
  @MaxLength(100)
  @Sanitize()
  name?: string;
}
```

### Presenters Security (src/adapters/controllers/[feature]/presenters)
- Never expose sensitive domain data
- Implement data masking for PII
- Use explicit field mapping, not object spreading
- Implement role-based data filtering
- Sanitize all output data

```typescript
// Good: Secure presenter (src/adapters/controllers/[feature]/presenters)
export class UserPresenter {
  id: string;
  email: string;
  name?: string;
  // Never include password, tokens, etc.

  static fromDomain(user: User, viewerRole: Role): UserPresenter {
    return {
      id: user.id.value,
      email: viewerRole.canViewEmail() ? user.email.value : '***@***.***',
      name: user.name?.value
    };
  }
}
```

