NODE_ENV=test
DATABASE_ENGINE=postgres
DATABASE_HOST=app-database-test
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres_test
DATABASE_SCHEMA=public
DATABASE_SYNCHRONIZE=false

### Postgres image init vars (used by db-test container via env_file)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres_test

### Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="We are currently under maintenance. Please check back later."

### JWT
JWT_SECRET=e2e-jwt-secret
JWT_EXPIRATION_TIME=30m
JWT_REFRESH_SECRET=e2e-jwt-refresh-secret
JWT_REFRESH_EXPIRATION_TIME=24h

CORS_ORIGIN=http://localhost:3001
